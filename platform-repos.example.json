{
  "$schema": "https://github.com/raintr91/platform-dna/blob/main/templates/schemas/platform-repos.schema.json",
  "defaultGroup": "tests",
  "harness": {
    "defaultByRole": {
      "tests": "tests"
    },
    "syncPolicy": {
      "mode": "propose",
      "description": "Current tests repository only; package init merges only package-owned tests skill IDs."
    },
    "profiles": {
      "tests": {
        "groups": [
          "tests"
        ],
        "skills": [
          "platform-ai",
          "platform-base",
          "testcase",
          "grill-testcase"
        ],
        "note": "E2E plans current repository only"
      }
    }
  },
  "groups": {
    "tests": {
      "description": "Tests hub current repository",
      "primary": "base-tests",
      "projects": [
        "base-tests"
      ]
    }
  },
  "projects": {
    "base-tests": {
      "root": ".",
      "role": "tests",
      "stack": "e2e-plans",
      "repo": "base-tests",
      "skill": "platform-ai",
      "description": "Base tests hub (R3) — E2E YAML/Markdown plans only",
      "write": true,
      "testRoots": {
        "landscape": "landscape",
        "scenarios": "scenarios",
        "cases": "cases",
        "suites": "suites"
      }
    }
  }
}
