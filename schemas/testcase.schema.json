{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://base-tests.local/schemas/testcase.schema.json",
  "title": "base-tests TC YAML",
  "type": "object",
  "required": ["id", "title", "coverage", "refs", "genType", "route", "testIds"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^TC-[A-Z0-9-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "story": { "type": "string" },
    "coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "happy",
          "validation",
          "boundary",
          "authorization",
          "state",
          "exception",
          "concurrency",
          "audit",
          "accessibility"
        ]
      }
    },
    "type": {
      "description": "Removed on base — use coverage",
      "not": {}
    },
    "refs": {
      "type": "object",
      "required": ["screen", "scenario", "target"],
      "properties": {
        "capability": { "type": "string" },
        "component": { "type": "string" },
        "feature": { "type": "string" },
        "rule": { "type": "string" },
        "scenario": { "type": "string" },
        "example": { "type": "string" },
        "screen": { "type": "string" },
        "target": { "type": "string" },
        "api": { "type": "string" }
      }
    },
    "genType": { "const": "e2e" },
    "feature": { "type": "string", "minLength": 1 },
    "route": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string" },
        "auth": { "type": "string" }
      }
    },
    "testIds": {
      "type": "object",
      "properties": {
        "required": { "type": "array", "items": { "type": "string" } }
      }
    },
    "a11y": {
      "type": "object",
      "properties": {
        "tags": { "type": "array", "items": { "type": "string" } },
        "include": { "type": "array", "items": { "type": "string" } },
        "exclude": { "type": "array", "items": { "type": "string" } },
        "disableRules": { "type": "array", "items": { "type": "string" } }
      }
    },
    "priority": { "type": "string" },
    "automation": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "preconditions": { "type": "array" },
    "testData": { "type": "object" },
    "steps": { "type": "array" },
    "expected": {},
    "postcondition": { "type": "array" },
    "dimensions": { "type": "object" },
    "scenario": { "type": "string" },
    "category": { "type": "string" }
  }
}
